# Copy to .env (local) and set the same vars in Vercel → Settings → Environment Variables.
# NEVER commit real values. .env* is gitignored.

# --- Gemini (AI coach + low-confidence parse fallback) ---
# Get a free key at https://aistudio.google.com  (starts with "AIza")
GEMINI_API_KEY=your_gemini_key_here

# --- Gmail auto-fetch (OAuth 2.0) ---
# Google Cloud Console → Credentials → OAuth client ID (Web application)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Local: http://localhost:3000/api/gmail/callback
# Prod:  https://YOUR-APP.vercel.app/api/gmail/callback  (also add it in Google Console)
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Gmail fetch window (UI input overrides these)
GMAIL_FETCH_DAYS=30
GMAIL_FETCH_MAX=50

# --- Supabase (OPTIONAL cloud persistence) ---
# Leave as placeholders to run localStorage-only. Set real values to persist to DB.
# Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
